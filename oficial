-- LÓGICA DUST II MAP
-- ==========================================
local function LoadDust2()
    local character = LP.Character or LP.CharacterAdded:Wait()
    local root = character:WaitForChild("HumanoidRootPart")
    local ALTURA_INICIAL = 5000
    local COOLDOWN = 2
    local ASSET_ID = 17343622288
    local DESTINO_FINAL = CFrame.new(15.6611328, 4955.0, -6.8840332, 1, 0, 0, 0, 1, 0, 0, 0, 0.999999881)

    root.Anchored = true
    root.CFrame = CFrame.new(root.Position.X, ALTURA_INICIAL, root.Position.Z)

    task.wait(COOLDOWN)

    local success, model = pcall(function()
        return game:GetObjects("rbxassetid://" .. ASSET_ID)[1]
    end)

    if success and model then
        model.Parent = game.Workspace
        if model:IsA("Model") then
            if model.PrimaryPart then
                model:SetPrimaryPartCFrame(DESTINO_FINAL * CFrame.new(0, -3, 0))
            else
                model:MoveTo(DESTINO_FINAL.Position - Vector3.new(0, 3, 0))
            end
        end
        task.wait(0.5)
        root.CFrame = DESTINO_FINAL
        task.wait(0.2)
        root.Anchored = false
    else
        root.Anchored = false
    end
end

